rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && request.auth.uid == userId 
        && incoming().keys().hasAll(['username', 'points', 'createdAt'])
        && incoming().keys().size() == 3
        && incoming().username is string && incoming().username.size() > 0 && incoming().username.size() <= 50
        && incoming().points is number
        && incoming().createdAt == request.time;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['username', 'points'])
        && (!incoming().diff(existing()).affectedKeys().hasAny(['username']) || (incoming().username is string && incoming().username.size() > 0 && incoming().username.size() <= 50))
        && (!incoming().diff(existing()).affectedKeys().hasAny(['points']) || (incoming().points is number));
    }
    
    match /notes/{noteId} {
      allow read: if true;
      allow create: if (
          (isSignedIn() && incoming().authorId == request.auth.uid) ||
          incoming().authorId == 'anonymous'
        )
        && incoming().keys().hasAll(['text', 'title', 'createdAt', 'authorId'])
        && (incoming().keys().size() == 4 || (incoming().keys().hasAll(['text', 'title', 'createdAt', 'authorId', 'authorUsername']) && incoming().keys().size() == 5))
        && incoming().text is string && incoming().text.size() > 0 && incoming().text.size() <= 100000
        && incoming().title is string && incoming().title.size() > 0 && incoming().title.size() <= 200
        && incoming().createdAt == request.time
        && incoming().authorId is string && incoming().authorId.size() > 0 && incoming().authorId.size() <= 128
        && (!('authorUsername' in incoming()) || (incoming().authorUsername is string && incoming().authorUsername.size() > 0 && incoming().authorUsername.size() <= 50));
    }
  }
}
